{
    "AppName": "KifuwaraperyCS",
    "ShogiEngineName": "KifuwaraperyCSharp",
    "ShogiEngineAuthor": "(Derivation)Takahashi Satoshi (Base)Hiraoka Takuya",

    "LoggingExtensions": {
        "Serilog": {
            "MinimumLevel": {
                "Default": "Information",
                "Override": {
                    "Microsoft": "Warning",
                    "System": "Warning",
                    "KifuwaraperyCS": "Information"
                }
            },
            "WriteTo": [
                {
                    "Name": "File",
                    "Args": {
                        "path": "Logs/Default-.log",
                        "rollingInterval": "Day"
                    }
                },
                {
                    "Name": "Logger",
                    "Args": {
                        "configureLogger": {
                            "Filter": [
                                {
                                    "Name": "ByIncludingOnly",
                                    "Args": {
                                        "expression": "SourceContext = 'MuzOthersLogger'"
                                    }
                                }
                            ],
                            "WriteTo": [
                                {
                                    "Name": "Console"
                                },
                                {
                                    "Name": "File",
                                    "Args": {
                                        "path": "Logs/Others-.log",
                                        "rollingInterval": "Day"
                                    }
                                }
                            ]
                        }
                    }
                },
                {
                    "Name": "Logger",
                    "Args": {
                        "configureLogger": {
                            "Filter": [
                                {
                                    "Name": "ByIncludingOnly",
                                    "Args": {
                                        "expression": "SourceContext = 'MuzVerboseLogger'"
                                    }
                                }
                            ],
                            "WriteTo": [
                                {
                                    "Name": "File",
                                    "Args": {
                                        "path": "Logs/Verbose-.log",
                                        "rollingInterval": "Day"
                                    }
                                }
                            ]
                        }
                    }
                },
                {
                    "Name": "Logger",
                    "Args": {
                        "configureLogger": {
                            "Filter": [
                                {
                                    "Name": "ByIncludingOnly",
                                    "Args": {
                                        "expression": "SourceContext = 'MuzOperationLogger'"
                                    }
                                }
                            ],
                            "WriteTo": [
                                {
                                    "Name": "File",
                                    "Args": {
                                        "path": "Logs/Operation-.log",
                                        "rollingInterval": "Day"
                                    }
                                }
                            ]
                        }
                    }
                },
                {
                    "Name": "Logger",
                    "Args": {
                        "configureLogger": {
                            "Filter": [
                                {
                                    "Name": "ByIncludingOnly",
                                    "Args": {
                                        "expression": "SourceContext = 'MuzUSIProtocolLogger'"
                                    }
                                }
                            ],
                            "WriteTo": [
                                {
                                    "Name": "File",
                                    "Args": {
                                        "path": "Logs/USIProtocol-.log",
                                        "rollingInterval": "Day",
                                        "outputTemplate": "{Message}"
                                    }
                                }
                            ]
                        }
                    }
                }
            ],
            "Enrich": [ "FromLogContext" ],
            "Properties": {
                "Application": "KifuwaraperyCS"
            }
        }
    }
}
