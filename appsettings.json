{
    "AppName": "KifuwaraperyCS",
    "ShogiEngineName": "KifuwaraperyCSharp",

    "CustomLogging": {
        "Serilog": {
            "MinimumLevel": {
                "Default": "Information",
                "Override": {
                    "KifuwaraperyCS": "Information"
                }
            },
            "WriteTo": [
                {
                    "Name": "Console"
                },
                {
                    "Name": "File",
                    "Args": {
                        "path": "logs/app-.log",
                        "rollingInterval": "Day"
                    }
                }
            ]
        }
    }
}

