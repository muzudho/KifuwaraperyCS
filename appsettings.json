{
    "AppName": "KifuwaraperyCS",
    "ShogiEngineName": "KifuwaraperyCSharp",

    "CustomLogging": {
        "Serilog": {
            "MinimumLevel": {
                "Default": "Information",
                "Override": {
                    "Microsoft": "Warning",
                    "System": "Warning",
                    "KifuwaraperyCS": "Information"
                }
            },
            "WriteTo": [
                {
                    "Name": "Console"
                },
                {
                    "Name": "File",
                    "Args": {
                        "path": "logs/app-.log",
                        "rollingInterval": "Day"
                    }
                }
            ],
            "Enrich": [ "FromLogContext" ],
            "Properties": {
                "Application": "KifuwaraperyCS"
            }
        }
    }
}

